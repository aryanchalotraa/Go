package main

import (
	"fmt"
	"image/color"
	"log"
	"math/rand"
	"time"

	"github.com/hajimehoshi/ebiten/v2"
	"github.com/hajimehoshi/ebiten/v2/ebitenutil"
)

const (
	screenWidth  = 800
	screenHeight = 600
	boxSize      = 50
	roundTime    = 105 // seconds (1 min 45 sec)
)

type Game struct {
	boxX      int
	boxY      int
	score     int
	bestScore int
	startTime time.Time
}

func (g *Game) resetRound() {
	if g.score > g.bestScore {
		g.bestScore = g.score
	}
	g.score = 0
	g.startTime = time.Now()
	g.boxX = rand.Intn(screenWidth - boxSize)
	g.boxY = rand.Intn(screenHeight - boxSize)
}

func (g *Game) Update() error {
	// Time check
	elapsed := int(time.Since(g.startTime).Seconds())
	if elapsed >= roundTime {
		g.resetRound()
	}

	// Move box randomly
	if rand.Intn(60) == 0 {
		g.boxX = rand.Intn(screenWidth - boxSize)
		g.boxY = rand.Intn(screenHeight - boxSize)
	}

	// Mouse click detection
	if ebiten.IsMouseButtonPressed(ebiten.MouseButtonLeft) {
		x, y := ebiten.CursorPosition()
		if x >= g.boxX && x <= g.boxX+boxSize &&
			y >= g.boxY && y <= g.boxY+boxSize {
			g.score++
			g.boxX = rand.Intn(screenWidth - boxSize)
			g.boxY = rand.Intn(screenHeight - boxSize)
		}
	}

	return nil
}

func (g *Game) Draw(screen *ebiten.Image) {
	screen.Fill(color.RGBA{0, 0, 0, 255})

	// Draw box
	box := ebiten.NewImage(boxSize, boxSize)
	box.Fill(color.RGBA{255, 0, 0, 255})

	op := &ebiten.DrawImageOptions{}
	op.GeoM.Translate(float64(g.boxX), float64(g.boxY))
	screen.DrawImage(box, op)

	// Time remaining
	elapsed := int(time.Since(g.startTime).Seconds())
	remaining := roundTime - elapsed
	if remaining < 0 {
		remaining = 0
	}

	min := remaining / 60
	sec := remaining % 60

	// Display info
	info := fmt.Sprintf(
		"Score: %d\nBest: %d\nTime: %02d:%02d",
		g.score,
		g.bestScore,
		min,
		sec,
	)

	ebitenutil.DebugPrint(screen, info)
}

func (g *Game) Layout(outsideWidth, outsideHeight int) (int, int) {
	return screenWidth, screenHeight
}

func main() {
	rand.Seed(time.Now().UnixNano())

	game := &Game{
		startTime: time.Now(),
		boxX:      rand.Intn(screenWidth - boxSize),
		boxY:      rand.Intn(screenHeight - boxSize),
	}

	ebiten.SetWindowSize(screenWidth, screenHeight)
	ebiten.SetWindowTitle("Click the Box - Timed Mode")

	if err := ebiten.RunGame(game); err != nil {
		log.Fatal(err)
	}
}
